{
  "experimentalServices": {
    "frontend": {
      "root": "frontend",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    "backend": {
      "root": "backend",
      "buildCommand": "pip install -r requirements.txt",
      "outputDirectory": "./"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://pronos26-api-staging.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/$1"
    }
  ]
}